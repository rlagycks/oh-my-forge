{
  "domain": "domain_skills",
  "version": "1.0",
  "source": [
    "skills/",
    ".agents/skills/"
  ],
  "summary": "144개 스킬 라이브러리. 특정 도메인 지식과 워크플로우를 담은 마크다운 파일. /skill-name 슬래시 커맨드로 호출하거나 Skill 툴로 실행. 두 배치 위치(큐레이션 vs 생성/임포트)를 구분.",
  "models": [
    {
      "name": "SkillFile",
      "fields": {
        "path": "string — skills/<name>/SKILL.md 또는 skills/<name>.md",
        "sections": {
          "When to Use": "string — 트리거 조건",
          "How It Works": "string — 단계별 동작",
          "Examples": "string — 사용 예시"
        },
        "frontmatter": "optional { description: string }"
      }
    }
  ],

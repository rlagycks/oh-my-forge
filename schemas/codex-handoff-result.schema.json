{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Handoff Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "state",
    "valid",
    "result",
    "filesChanged",
    "tests",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "enum": [
        "ecc.codex.handoff.result.v1",
        "ecc.codex.handoff.result.v2",
        "ecc.codex.handoff.result.v3"
      ]
    },
    "state": {
      "enum": ["COMPLETED", "BLOCKED", "PARTIAL"]
    },
    "valid": {
      "type": "boolean"
    },
    "result": {
      "enum": ["DONE", "BLOCKED", "PARTIAL"]
    },
    "filesChanged": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "tests": {
      "enum": ["PASS", "FAIL", "SKIPPED"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "reasonCode": {
      "enum": ["accepted", "false-normal", "missing-result"]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "falseNormalChecks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "falseNormalSignals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "openRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "error": {
      "type": "string",
      "minLength": 1
    },
    "rawOutput": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schemaVersion": {
            "const": "ecc.codex.handoff.result.v2"
          }
        }
      },
      "then": {
        "required": [
          "evidence",
          "falseNormalChecks",
          "openRisks",
          "nextAction"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "schemaVersion": {
            "const": "ecc.codex.handoff.result.v3"
          }
        }
      },
      "then": {
        "required": [
          "evidence",
          "falseNormalChecks",
          "falseNormalSignals",
          "openRisks",
          "nextAction"
        ]
      }
    }
  ]
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Handoff Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "state",
    "engine",
    "source",
    "mode",
    "write",
    "routingRoot",
    "planFile",
    "task",
    "files"
  ],
  "properties": {
    "schemaVersion": {
      "enum": [
        "ecc.codex.handoff.request.v1",
        "ecc.codex.handoff.request.v2"
      ]
    },
    "kind": {
      "enum": ["domain", "fallback"]
    },
    "state": {
      "enum": ["PLANNED", "ROUTED", "DISPATCHED"]
    },
    "engine": {
      "enum": ["codex", "claude"]
    },
    "source": {
      "enum": ["plan-auto", "manual-delegate", "manual-rescue"]
    },
    "mode": {
      "enum": ["foreground", "background"]
    },
    "write": {
      "type": "boolean"
    },
    "routingRoot": {
      "type": "string",
      "minLength": 1
    },
    "planFile": {
      "type": "string",
      "minLength": 1
    },
    "featureName": {
      "type": "string",
      "minLength": 1
    },
    "domainId": {
      "type": "string",
      "minLength": 1
    },
    "task": {
      "type": "string",
      "minLength": 1
    },
    "problemOneLine": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notDo": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completionChecks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "endpoints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "symbols": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "schemaVersion": {
            "const": "ecc.codex.handoff.request.v2"
          }
        }
      },
      "then": {
        "required": [
          "problemOneLine",
          "successCriteria",
          "completionChecks"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "source": {
            "enum": ["plan-auto", "manual-delegate", "manual-rescue"]
          }
        }
      },
      "then": {
        "properties": {
          "write": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "source": {
            "const": "plan-auto"
          }
        }
      },
      "then": {
        "properties": {
          "mode": {
            "const": "foreground"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "domain"
          }
        }
      },
      "then": {
        "required": ["domainId"]
      },
      "else": {
        "not": {
          "required": ["domainId"]
        }
      }
    }
  ]
}
